    {
      "parameters": {
        "jsCode": "const questions = $('Fetch Questions').all().map(i => i.json);\nconst answers = $('Fetch Answers').all().map(i => i.json);\nconst proctoringEvents = $('Fetch Proctoring').all().map(i => i.json);\nconst session = $('Fetch Session').item?.json;\nconst resume = $('Fetch Resume').item?.json;\nconst jd = $('Fetch JD').item?.json;\nconst sessionId = session?.id;\nconst answerMap = {};\nanswers.forEach(a => { if (a.question_id) { answerMap[a.question_id] = a.answer_text; } });\nconst qa = questions.map((q) => ({ question: q.question_text, type: q.question_type, is_follow_up: q.source === 'llm_ts_followup' || q.source === 'live_followup', source: q.source, parent_question_id: q.parent_question_id || null, answer: answerMap[q.id] || '[no answer provided]' }));\nconst summary = { totalEvents: proctoringEvents.length, criticalEvents: proctoringEvents.filter(e => e.severity === 'critical').length, warningEvents: proctoringEvents.filter(e => e.severity === 'warning').length, tabSwitches: proctoringEvents.filter(e => e.event_type === 'tab_switch' || e.event_type === 'window_blur').length, faceAbsences: proctoringEvents.filter(e => e.event_type === 'face_absent').length, faceMultiple: proctoringEvents.filter(e => e.event_type === 'face_multiple').length, silentPeriods: proctoringEvents.filter(e => e.event_type === 'audio_silence').length, fullscreenExits: proctoringEvents.filter(e => e.event_type === 'fullscreen_exit').length, copyPastes: proctoringEvents.filter(e => e.event_type === 'copy_paste').length };\nreturn { session_id: sessionId, resumeText: resume?.raw_text || '', jdText: jd?.raw_text || '', answers: qa, proctoringSummary: summary };"
      },
