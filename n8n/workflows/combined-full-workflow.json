      "parameters": {
        "jsCode": "const sessionId = $node[\"Build Prompt\"].json.session_id;\nreturn items.map(item => {\n  try {\n    const content = item.json.choices?.[0]?.message?.content;\n    if (!content) throw new Error('No content in LLM response');\n    const c = JSON.parse(content);\n    return { json: { session_id: sessionId, technical_score: c.technical_score ?? 0, communication_score: c.communication_score ?? 0, problem_solving_score: c.problem_solving_score ?? 0, cultural_fit_score: c.cultural_fit_score ?? 0, overall_score: c.overall_score ?? 0, authenticity_score: c.authenticity_score ?? 0, red_flag_count: c.red_flag_count ?? 0, red_flags: c.red_flags || [], resume_vs_reality: c.resume_vs_reality || [], strengths: c.strengths || [], weaknesses: c.weaknesses || [], recommendation: c.recommendation || 'consider', ai_rationale: c.ai_rationale || 'No rationale provided by LLM', detailed_rationale: c.detailed_rationale || '', scoring_model_version: 'llama-3.3-70b-versatile-v2' } };\n  } catch (e) {\n    return { json: { session_id: sessionId, technical_score: 0, communication_score: 0, problem_solving_score: 0, cultural_fit_score: 0, overall_score: 0, authenticity_score: 0, red_flag_count: 0, red_flags: [], resume_vs_reality: [], strengths: [], weaknesses: ['Scoring failed - LLM response was invalid'], recommendation: 'consider', ai_rationale: 'The scoring pipeline encountered an error parsing the LLM response. Manual review is recommended.', detailed_rationale: '', scoring_model_version: 'llama-3.3-70b-versatile-v2' } };\n  }\n});"
