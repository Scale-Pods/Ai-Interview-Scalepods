      "parameters": {
        "jsCode": "function uuid() {\n  return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, c => {\n    const r = Math.random() * 16 | 0;\n    return (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);\n  });\n}\nconst input = items[0].json.body || items[0].json;\nconst sessionId = uuid();\nconst expiresAt = new Date(Date.now() + 1 * 24 * 60 * 60 * 1000);\nconst baseUrl = input.frontendUrl || items[0].json.frontendUrl || 'http://localhost:5173';\nconst inviteLink = `${baseUrl}/interview/${sessionId}`;\nconst candidateEmail = input.candidate_email || input.email;\nconst candidateName = input.candidate_name || input.name || 'Candidate';\nif (!candidateEmail) {\n  throw new Error('Missing candidate email. Send email or candidate_email in the webhook body.');\n}\nreturn {\n  ...input,\n  candidate_email: candidateEmail,\n  candidate_name: candidateName,\n  session_id: sessionId,\n  invite_link: inviteLink,\n  token_hash: sessionId,\n  expires_at: expiresAt.toISOString(),\n  status: 'invited'\n};"
