    {
      "parameters": {
        "jsCode": "// 1. Explicitly pull data from the specific nodes\n// This ignores the input stream of the node and fetches the full result sets\nconst questions = $('Fetch Questions').all().map(i => i.json);\nconst answers = $('Fetch Answers').all().map(i => i.json);\nconst proctoringEvents = $('Fetch Proctoring').all().map(i => i.json);\nconst session = $('Fetch Session').item?.json;\n\nconst sessionId = session?.id;\n\n// 2. Build the Answer Map\nconst answerMap = {};\nanswers.forEach(a => {\n  if (a.question_id) {\n    answerMap[a.question_id] = a.answer_text;\n  }\n});\n\n// 3. Construct the Q&A chain\nconst qa = questions.map((q) => ({\n  question: q.question_text,\n  type: q.question_type,\n  is_follow_up: q.source === 'live_followup',\n  source: q.source,\n  parent_question_id: q.parent_question_id || null,\n  answer: answerMap[q.id] || '[no answer provided]'\n}));\n\n// 4. Build the Proctoring Summary\nconst summary = {\n  totalEvents: proctoringEvents.length,\n  criticalEvents: proctoringEvents.filter(e => e.severity === 'critical').length,\n  warningEvents: proctoringEvents.filter(e => e.severity === 'warning').length,\n  tabSwitches: proctoringEvents.filter(e => e.event_type === 'tab_switch' || e.event_type === 'window_blur').length,\n  faceAbsences: proctoringEvents.filter(e => e.event_type === 'face_absent').length,\n  faceMultiple: proctoringEvents.filter(e => e.event_type === 'face_multiple').length,\n  silentPeriods: proctoringEvents.filter(e => e.event_type === 'audio_silence').length,\n  fullscreenExits: proctoringEvents.filter(e => e.event_type === 'fullscreen_exit').length,\n  copyPastes: proctoringEvents.filter(e => e.event_type === 'copy_paste').length\n};\n\nreturn { \n  session_id: sessionId, \n  prompt: `Q&A: ${JSON.stringify(qa)}\\nProctoring: ${JSON.stringify(summary)}`\n};"
      },
      "id": "57fcdbd5-4da5-44f9-aeb4-6294c74449fd",
      "name": "Build Prompt",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
